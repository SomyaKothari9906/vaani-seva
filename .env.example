# ========================================
# VaaniSeva - Environment Variables Template
# ========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# --- AWS ---
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# --- Twilio (from Somya) ---
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+12602048966

# --- Sarvam AI TTS (primary, better Hindi quality) ---
SARVAM_API_KEY=your_sarvam_api_key_here

# --- AWS Bedrock (fallback LLM + embeddings) ---
BEDROCK_MODEL_ID=amazon.nova-micro-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# --- OpenAI (primary LLM — much better conversation quality) ---
OPENAI_API_KEY=your_openai_api_key_here
LLM_PROVIDER=openai

# --- DynamoDB Table Names ---
DYNAMODB_CALLS_TABLE=vaaniseva-calls
DYNAMODB_KNOWLEDGE_TABLE=vaaniseva-knowledge
DYNAMODB_VECTORS_TABLE=vaaniseva-vectors

# --- S3 ---
S3_DOCUMENTS_BUCKET=vaaniseva-documents

# --- Auth ---
JWT_SECRET=your_jwt_secret_here
DYNAMODB_USERS_TABLE=vaaniseva-users

# --- WebSocket ---
DYNAMODB_WS_CONNECTIONS_TABLE=vaaniseva-ws-connections

# --- data.gov.in (optional — live scheme data) ---
DATA_GOV_API_KEY=your_data_gov_api_key_here

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
